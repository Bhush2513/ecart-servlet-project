<web-app>
  <display-name>Archetype Created Web Application</display-name>
  <servlet>
  	<servlet-name>Logoutservlet</servlet-name>
  	<display-name>Logoutservlet</display-name>
  	<description></description>
  	<servlet-class>com.project.controller.Logoutservlet</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>ResetPasswordServlet</servlet-name>
  	<display-name>ResetPasswordServlet</display-name>
  	<description></description>
  	<servlet-class>com.project.controller.ResetPasswordServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  	<servlet-name>Logoutservlet</servlet-name>
  	<url-pattern>/Logoutservlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>ResetPasswordServlet</servlet-name>
  	<url-pattern>/ResetPasswordServlet</url-pattern>
  </servlet-mapping>
</web-app>
